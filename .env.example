# Project root (optional; auto-detected from package location)
# PROJECT_ROOT=/path/to/divar_project

# Directory containing raw and processed data (default: <project_root>/data)
DATA_DIR=./data

# Path to main Divar CSV (default: <DATA_DIR>/raw/Divar.csv)
DIVAR_CSV=./data/raw/Divar.csv

# Optional secondary dataset (statistical analysis)
IRAN_CITY_CSV=./data/raw/iran_city_classification.csv
